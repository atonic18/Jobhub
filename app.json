{
  "expo": {
    "name": "JobHub",
    "slug": "jobhub",
    "scheme": "jobhub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F8FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jobhub.app"
    },
    "android": {
      "package": "com.jobhub.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "appwriteEndpoint": "https://sfo.cloud.appwrite.io/v1",
      "appwriteProjectId": "1212125"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
